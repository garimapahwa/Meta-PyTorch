# Local runtime configuration
# Copy this file to `.env` and fill in your Datadog credentials.

# Optional for the dashboard itself; required for inference.py only.
OPENAI_API_KEY=
API_BASE_URL=https://api.openai.com/v1
MODEL_NAME=gpt-3.5-turbo
HF_TOKEN=

# Datadog integration for logs, metrics, and APM in the dashboard.
DD_API_KEY=
DD_APP_KEY=
DD_SITE=datadoghq.com

# Optional: comma-separated log indexes to search, for example:
# DD_LOG_INDEXES=main,service-logs
DD_LOG_INDEXES=

# Elasticsearch integration for dashboard logs.
# If ELASTICSEARCH_URL is set, `/api/logs` prefers Elasticsearch over Datadog.
ELASTICSEARCH_URL=
ELASTICSEARCH_API_KEY=
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_LOG_INDEX=logs-*
ELASTICSEARCH_TIMESTAMP_FIELD=@timestamp
ELASTICSEARCH_SERVICE_FIELD=service
ELASTICSEARCH_MESSAGE_FIELD=message
ELASTICSEARCH_LEVEL_FIELD=log.level
ELASTICSEARCH_VERIFY_TLS=true
